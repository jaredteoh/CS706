# GitHub API token (required for fetching issues in Stage 2)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI (required for --model gpt-4o or --model o3)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (required for --model claude-3-7-sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (required for --model gemini-2.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek (required for --model deepseek-v3)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
